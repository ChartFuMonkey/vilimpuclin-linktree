---
interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden bg-black">
  <!-- Default: SVG shield (always present). Hidden if the PNG override loads. -->
  <div
    id="bg-logo-svg"
    class="absolute inset-x-0 top-1/2 -translate-y-[55%] flex items-center justify-center"
    aria-hidden="true"
  >
    <img
      src="/assets/logo-bg.svg"
      alt=""
      class="w-[min(110vw,1100px)] max-h-[92vh] object-contain opacity-[0.22] select-none"
      draggable="false"
    />
  </div>

  <!-- Optional override: upload /assets/s1-logo.png to use a real brand mark -->
  <div
    id="bg-logo-png"
    class="absolute inset-x-0 top-1/2 -translate-y-[55%] hidden items-center justify-center"
    aria-hidden="true"
  >
    <img
      src="/assets/s1-logo.png"
      alt=""
      onload="document.getElementById('bg-logo-svg').style.display='none';document.getElementById('bg-logo-png').style.display='flex';"
      onerror="this.parentElement.style.display='none'"
      class="w-[min(110vw,1100px)] max-h-[92vh] object-contain opacity-[0.14] select-none"
      draggable="false"
    />
  </div>

  <!-- Faded wordmark strip along the bottom -->
  <div
    class="absolute inset-x-0 bottom-[5%] flex flex-col items-center px-4 text-center"
    aria-hidden="true"
  >
    <div
      class="font-display font-bold uppercase tracking-[0.02em] leading-[0.9] text-gold/[0.22]"
      style="font-size: clamp(2.25rem, 10vw, 9rem);"
    >
      {title} {subtitle}
    </div>
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/70"></div>
</div>
