---
interface Props {
  title: string;
  subtitle: string;
  tagline?: string;
}
const { title, subtitle, tagline } = Astro.props;
---

<header class="flex flex-col items-center text-center pt-10 pb-6 px-4">
  <img
    src="/assets/s1-logo.png"
    alt={`${title} ${subtitle}`}
    onerror="this.onerror=null;this.src='/assets/logo-bg.svg'"
    class="w-28 h-28 sm:w-32 sm:h-32 object-contain drop-shadow-[0_4px_20px_rgba(245,184,0,0.25)]"
  />
  <h1 class="mt-5 font-display font-bold uppercase tracking-[0.03em] text-white text-3xl sm:text-4xl">
    {title}
  </h1>
  <p class="mt-1 font-display font-semibold uppercase tracking-[0.25em] text-gold text-sm sm:text-base">
    {subtitle}
  </p>
  {tagline && (
    <p class="mt-3 max-w-xs text-xs sm:text-sm text-white/60 leading-relaxed">
      {tagline}
    </p>
  )}
</header>
