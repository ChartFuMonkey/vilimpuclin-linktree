---
interface Props {
  handle: string;
  url?: string;
}
const { handle, url } = Astro.props;
const href = url ?? `https://instagram.com/${handle.replace(/^@/, "")}`;
---

<footer class="mt-10 pb-10 flex flex-col items-center gap-2">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/60 px-4 py-2 text-sm text-white/80 hover:text-white hover:border-gold/60 transition"
  >
    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
      <path
        d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm0 2h10c1.66 0 3 1.34 3 3v10c0 1.66-1.34 3-3 3H7c-1.66 0-3-1.34-3-3V7c0-1.66 1.34-3 3-3zm10.5 2a1 1 0 100 2 1 1 0 000-2zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z"
      ></path>
    </svg>
    <span>{handle}</span>
  </a>
</footer>
